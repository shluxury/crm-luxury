# ============================================================
# CRM Luxury - Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# JAMAIS committer .env.local dans git
# ============================================================

# --- Supabase ---
# URL et clé anon : côté client (préfixe NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_supabase

# --- Google Maps ---
# Clé publique - restreindre aux domaines autorisés dans Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_KEY=votre_cle_google_maps

# --- Stripe ---
# Clé publique uniquement côté client
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_xxxxx

# --- Secrets (jamais côté client, Server Actions uniquement) ---
BREVO_API_KEY=votre_cle_brevo
BREVO_SENDER_EMAIL=contact@votresociete.com
BREVO_SENDER_NAME=Votre Société

STRIPE_SECRET_KEY=sk_live_xxxxx

AVIATIONSTACK_API_KEY=votre_cle_aviationstack

ANTHROPIC_API_KEY=votre_cle_anthropic
